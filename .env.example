# MailGym environment variables — copy to .env and fill in
# ---------------------------------------------------------
# .env is gitignored. Never commit real tokens.
#
# Load into your shell with:
#     set -a && source .env && set +a
#
# Or run inference with:
#     env $(cat .env | xargs) python3 inference.py

# LLM endpoint (HF Inference Router is the default)
API_BASE_URL=https://router.huggingface.co/v1

# Model identifier used for all LLM calls
MODEL_NAME=meta-llama/Llama-3.1-8B-Instruct

# HuggingFace / API token — required
HF_TOKEN=hf_replace_me

# MailGym server URL
# Local:  http://localhost:7860
# Live:   https://myan9417-mailgym.hf.space
ENV_BASE_URL=http://localhost:7860
